generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserAwarenessScore {
  id         Int       @id @default(autoincrement())
  user_email String    @unique @db.VarChar(255)
  score      Int?      @default(0)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("user_awareness_scores")
}

model AnalysisLog {
  id              Int       @id @default(autoincrement())
  user_email      String?   @db.VarChar(255)
  content         String
  type            String    @db.VarChar(50)
  classification  String    @db.VarChar(50)
  severity        String    @db.VarChar(20)
  explanation     String?
  recommendations String?
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  @@map("analysis_logs")
}

model Simulation {
  id            Int       @id @default(autoincrement())
  user_email    String?   @db.VarChar(255)
  scenario_name String    @db.VarChar(255)
  success       Boolean
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  @@map("simulations")
}

model users {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar
  email         String    @unique @db.VarChar
  password_hash String?   @db.VarChar
  role          String    @default("volunteer") @db.VarChar
  is_verified   Boolean?  @default(false)
  google_id     String?   @unique @db.VarChar
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model verification_codes {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar
  code       String   @db.VarChar(6)
  expires_at DateTime @db.Timestamp(6)
}

model ThreatIntelligenceCache {
  id             String   @id @default(cuid())
  fileHash       String   @unique
  maliciousVotes Int
  totalVendors   Int
  isMalware      Boolean
  lastScannedAt  DateTime @default(now())
}

model CommunityMessage {
  id         Int       @id @default(autoincrement())
  user_email String    @db.VarChar(255)
  content    String
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("community_messages")
}
